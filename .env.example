# Firebase Configuration
# Get these values from your Firebase Console: https://console.firebase.google.com/
# Project Settings > General > Your apps > Firebase SDK snippet > Config

VITE_FIREBASE_CONFIG='{"apiKey":"YOUR_API_KEY","authDomain":"YOUR_PROJECT_ID.firebaseapp.com","projectId":"YOUR_PROJECT_ID","storageBucket":"YOUR_PROJECT_ID.appspot.com","messagingSenderId":"YOUR_MESSAGING_SENDER_ID","appId":"YOUR_APP_ID"}'

# App ID (can be any unique identifier for your app instance)
VITE_APP_ID="fact-family-math-app"

# Optional: Custom authentication token (leave empty to use anonymous auth)
VITE_INITIAL_AUTH_TOKEN=""
